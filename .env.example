# Panadería Luz Marina — variables de entorno del backend
# Copia este archivo a `.env` y ajusta los valores. NO subas `.env` al repositorio.

# Puerto del servidor Express. Opcional (por defecto 3001).
PORT=3001

# Origen permitido para CORS. En producción debe ser la URL del frontend,
# p. ej. https://tu-sitio.netlify.app. Sin él, se rechazan las peticiones cruzadas.
FRONTEND_ORIGIN=http://localhost:3000

# Token/contraseña del panel de administración.
# Sin él, el panel admin queda inaccesible. Usa un valor largo y secreto.
ADMIN_TOKEN=cambia-esto-por-un-token-secreto

# Secreto para firmar los tokens de sesión del panel (HMAC). Recomendado uno
# dedicado y distinto del ADMIN_TOKEN. Si se omite, se deriva del ADMIN_TOKEN.
# Genera uno con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=cambia-esto-por-otro-secreto-largo

# Duración de la sesión admin en milisegundos. Opcional (por defecto 8h).
SESSION_TTL_MS=28800000

# Máximo de intentos de login por IP cada 15 min. Opcional (por defecto 10).
AUTH_MAX_ATTEMPTS=10

# Máximo de creaciones de orden por IP cada 15 min. Opcional (por defecto 20).
ORDERS_MAX_PER_WINDOW=20

# Ruta del archivo SQLite. Opcional (por defecto ./luzmarina.db).
DB_PATH=./luzmarina.db
